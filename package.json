{
  "name": "api-gateway",
  "version": "1.0.0",
  "description": "API Gateway for hospital management microservices",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "test": "jest --coverage --forceExit",
    "build": "cd ../frontend && npm install && npm run build && cd ../user-service && npm install",
    "deploy:full": "npm install && npm start"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": ["src/**/*.js"]
  },
  "author": "Dupont corporation",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "http-proxy-middleware": "^2.0.7",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.1.0"
  }
}
